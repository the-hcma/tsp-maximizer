{
  "name": "@the-hcma/tsp-maximizer",
  "version": "1.3.0",
  "description": "A no-install web calculator to maximize TSP contributions and agency matching for federal employees.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-hcma/tsp-maximizer.git"
  },
  "homepage": "https://github.com/the-hcma/tsp-maximizer",
  "keywords": [
    "tsp",
    "thrift-savings-plan",
    "federal-employees",
    "retirement",
    "calculator",
    "brs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "tsp-maximizer": "./bin/tsp-maximizer.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "predev": "pnpm install",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "check": "tsc -b && eslint .",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
